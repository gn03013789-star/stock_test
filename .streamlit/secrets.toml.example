# 範本檔：請勿把真正的 secrets.toml 提交到 GitHub。
#
# 本機測試：複製本檔為 .streamlit/secrets.toml 並填入你的值。
# Streamlit Community Cloud：到 App 的「Settings → Secrets」貼上以下內容。

# 存取密碼（設定後即啟用密碼門；留空或不設定則為公開）
APP_PASSWORD = "change-me-please"

# 可選：SEC EDGAR 要求帶可識別的 User-Agent，建議填你的聯絡方式
# STOCK_REPORT_SEC_UA = "YourName research you@example.com"

# 可選：關閉英文新聞翻譯（"0" 為關閉）
# STOCK_REPORT_TRANSLATE = "1"
